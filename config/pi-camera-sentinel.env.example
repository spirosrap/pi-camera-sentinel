# Telegram delivery.
# Create a bot with BotFather, message the bot once, then run:
#   pi-camera-sentinel show-chat-ids
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Camera source.
# ustreamer serves these locally; Tailscale Serve can expose the feed privately.
SENTINEL_SNAPSHOT_URL=http://127.0.0.1:8080/snapshot
SENTINEL_STREAM_URL=http://127.0.0.1:8080/stream
SENTINEL_FEED_URL=
SENTINEL_CAMERA_DEVICE=/dev/video0

# Motion detection.
SENTINEL_POLL_SECONDS=1.0
SENTINEL_DIFF_THRESHOLD=25
SENTINEL_CHANGED_RATIO=0.035
SENTINEL_MIN_FRAMES=2
SENTINEL_COOLDOWN_SECONDS=60
SENTINEL_RESIZE_WIDTH=160
SENTINEL_RESIZE_HEIGHT=90

# Telegram media behavior.
SENTINEL_SEND_PHOTO=1
SENTINEL_SEND_VIDEO=0
SENTINEL_ALERT_BATCH_SECONDS=8
SENTINEL_ALERT_BATCH_MAX_PHOTOS=4
SENTINEL_VIDEO_SECONDS=5
SENTINEL_VIDEO_FPS=10

# Local event retention on the Pi.
SENTINEL_OUTPUT_DIR=/var/lib/pi-camera-sentinel
SENTINEL_RETENTION_FILES=200
# Set an optional limit to 0 to disable that specific rule.
SENTINEL_RETENTION_DAYS=0
SENTINEL_RETENTION_MB=0
SENTINEL_DISK_MIN_FREE_MB=512

# Telegram quiet-hours policy. Use an IANA timezone such as Europe/Athens,
# or leave local to follow the Pi's system timezone.
SENTINEL_POLICY_FILE=/var/lib/pi-camera-sentinel/alert-policy.json
SENTINEL_MASK_FILE=/var/lib/pi-camera-sentinel/motion-masks.json
SENTINEL_TIMEZONE=local

# Optional Home Assistant webhook. Keep the webhook ID private.
SENTINEL_HOME_ASSISTANT_WEBHOOK_URL=
SENTINEL_WEBHOOK_TIMEOUT=5

# Private web dashboard. The loopback default is intended for Tailscale Serve.
SENTINEL_DASHBOARD_HOST=127.0.0.1
SENTINEL_DASHBOARD_PORT=8090
SENTINEL_DASHBOARD_TITLE=Pi Camera Sentinel
SENTINEL_DASHBOARD_STATUS_CACHE_SECONDS=5

# Services controlled from the private dashboard.
SENTINEL_MOTION_SERVICE=pi-camera-motion.service
SENTINEL_EXPOSURE_SERVICE=pi-camera-exposure-watchdog.service
SENTINEL_RECOVERY_SERVICE=pi-camera-recovery-watchdog.service
SENTINEL_HEALTH_SERVICE=pi-camera-health-watchdog.service
SENTINEL_STREAM_SERVICE=pi-camera-stream.service

# Automatic feed recovery. Three consecutive failures are required before a
# restart, and the cooldown prevents a faulty camera from entering a restart loop.
SENTINEL_RECOVERY_STATE_FILE=/var/lib/pi-camera-sentinel/recovery-state.json
SENTINEL_RECOVERY_INTERVAL_SECONDS=15
SENTINEL_RECOVERY_FAILURE_THRESHOLD=3
SENTINEL_RECOVERY_STALE_SECONDS=20
SENTINEL_RECOVERY_COOLDOWN_SECONDS=120
# Send operational restart and recovery updates through the configured Telegram bot.
SENTINEL_RECOVERY_TELEGRAM_ALERTS=0

# Confirm repeated Pi power, temperature, and storage transitions before
# sending operational Telegram updates. Existing conditions are baselined.
SENTINEL_HEALTH_STATE_FILE=/var/lib/pi-camera-sentinel/health-alert-state.json
SENTINEL_HEALTH_INTERVAL_SECONDS=60
SENTINEL_HEALTH_FAILURE_THRESHOLD=3
SENTINEL_HEALTH_RECOVERY_THRESHOLD=2
SENTINEL_HEALTH_TEMPERATURE_MAX_C=80
SENTINEL_HEALTH_TELEGRAM_ALERTS=0

# Exposure watchdog. It samples the current snapshot and switches camera
# profiles when the frame is almost black or washed out.
SENTINEL_EXPOSURE_WATCHDOG_INTERVAL=60
SENTINEL_EXPOSURE_SETTLE_SECONDS=8
SENTINEL_EXPOSURE_DARK_MEAN_MAX=45
SENTINEL_EXPOSURE_DARK_RATIO_MIN=0.25
SENTINEL_EXPOSURE_DARK_PIXEL_MAX=25
SENTINEL_EXPOSURE_BRIGHT_MEAN_MIN=230
SENTINEL_EXPOSURE_BRIGHT_RATIO_MIN=0.85
SENTINEL_EXPOSURE_BRIGHT_PIXEL_MIN=180
SENTINEL_EXPOSURE_DAY_PROFILE=auto
SENTINEL_EXPOSURE_NIGHT_PROFILE=low-light
