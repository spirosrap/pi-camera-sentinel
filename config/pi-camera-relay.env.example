# Bind only to loopback; Tailscale Serve supplies private HTTPS.
SENTINEL_RELAY_HOST=127.0.0.1
SENTINEL_RELAY_PORT=8091

# The Pi dashboard may be reached through a restricted SSH tunnel, while camera
# media should use the local LAN so the Pi does not encrypt the MJPEG stream.
SENTINEL_RELAY_DASHBOARD_URL=http://127.0.0.1:18090
SENTINEL_RELAY_STREAM_URL=http://pi-camera.local:8080/stream
SENTINEL_RELAY_SNAPSHOT_URL=http://pi-camera.local:8080/snapshot

SENTINEL_RELAY_CONNECT_TIMEOUT=5
SENTINEL_RELAY_REQUEST_TIMEOUT=30
SENTINEL_RELAY_LOG_LEVEL=INFO
