[Unit]
Description=Pi Camera Sentinel exposure watchdog
After=network-online.target pi-camera-stream.service
Wants=network-online.target pi-camera-stream.service

[Service]
Type=simple
EnvironmentFile=/etc/pi-camera-sentinel.env
ExecStart=/usr/local/bin/pi-camera-sentinel exposure-watchdog
Restart=always
RestartSec=10
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=full

[Install]
WantedBy=multi-user.target
